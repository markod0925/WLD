{
  "blocked_processes": [
    "chrome.exe",
    "msedge.exe",
    "webex.exe"
  ],
  "screenshot_interval_seconds": 60,
  "capture_mode": "active_window",
  "foreground_poll_interval_seconds": 1.0,
  "text_inactivity_gap_seconds": 8.0,
  "reconstruction_poll_interval_seconds": 2.0,
  "flush_interval_seconds": 300,
  "lmstudio_base_url": "http://127.0.0.1:1234/v1",
  "lmstudio_model": "local-model",
  "app_data_dir": "C:/Users/<you>/AppData/Local/WorkLogDiary",
  "screenshot_dir": "C:/Users/<you>/AppData/Local/WorkLogDiary/screenshots",
  "log_dir": "C:/Users/<you>/AppData/Local/WorkLogDiary/logs",
  "db_path": "C:/Users/<you>/AppData/Local/WorkLogDiary/worklog_diary.db",
  "config_path": "C:/Users/<you>/AppData/Local/WorkLogDiary/config.json",
  "start_monitoring_on_launch": false,
  "max_screenshots_per_summary": 3,
  "max_text_segments_per_summary": 400,
  "max_parallel_summary_jobs": 2,
  "request_timeout_seconds": 600,
  "activity_segment_min_duration_seconds": 180.0,
  "activity_segment_max_duration_seconds": 900.0,
  "activity_segment_idle_gap_seconds": 20.0,
  "activity_segment_title_similarity_threshold": 0.72,
  "summary_similarity_suppress_threshold": 0.86,
  "summary_similarity_merge_threshold": 0.74,
  "summary_cooldown_seconds": 240,
  "recent_summary_compare_count": 5,
  "screenshot_dedup_exact_hash_enabled": true,
  "screenshot_dedup_perceptual_hash_enabled": true,
  "screenshot_dedup_phash_threshold": 6,
  "screenshot_dedup_ssim_enabled": true,
  "screenshot_dedup_ssim_threshold": 0.985,
  "screenshot_dedup_resize_width": 32,
  "screenshot_dedup_compare_recent_count": 8,
  "screenshot_dedup_enabled": true,
  "screenshot_dedup_threshold": 6,
  "screenshot_min_keep_interval_seconds": 120
}
